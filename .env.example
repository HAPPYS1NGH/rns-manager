# Copy this file to .env and fill in your values.
# Never commit .env to git.

# WalletConnect Cloud project ID
# Get one free at https://cloud.walletconnect.com
VITE_WC_PROJECT_ID=your_walletconnect_project_id_here

# Alchemy API key (if used for RPC transport)
# Get one at https://dashboard.alchemy.com
# VITE_ALCHEMY_API_KEY=your_alchemy_api_key_here

# The Graph RNS subgraph URL (used by rns-manager to resolve subname labels)
# Example (replace [api-key] with your key from Subgraph Studio):
# VITE_RNS_SUBGRAPH_URL=https://gateway-arbitrum.network.thegraph.com/api/[api-key]/subgraphs/id/DhBgWdhFsujyqFmYqaTwUyyYm5QWBEhqVnBHek9JYPkn
